#!/usr/bin/env bash
# bats-vendor/bin/bats — Minimal bats-core compatible runner (vendored)
# Compatible with bats-core syntax: @test, setup, teardown, run, assert_*
# Vendored so the project works offline and in CI without external dependencies.
# Based on bats-core (https://github.com/bats-core/bats-core), MIT License.

set -euo pipefail
IFS=$'\n\t'

VERSION="1.0.0-vendored"

BATS_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BATS_LIB="$BATS_ROOT/lib"

##############################################################################
# Globals set per-test (reset between each @test block)
##############################################################################
BATS_TEST_NAME=""
BATS_TEST_FILENAME=""
output=""       # stdout+stderr of last `run` command
status=0        # exit code of last `run` command
lines=()        # output split by lines

TESTS_RUN=0
TESTS_PASSED=0
TESTS_FAILED=0
TESTS_SKIPPED=0

declare -a FAILED_TESTS=()

##############################################################################
# run  — execute a command, capturing output and status without failing
# Usage: run <command> [args...]
##############################################################################
run() {
    local cmd=("$@")
    output=""
    status=0
    output=$(set +e; "${cmd[@]}" 2>&1; echo "EXIT:$?") || true
    # Extract exit code appended as last line
    local last_line
    last_line=$(echo "$output" | tail -n1)
    if [[ "$last_line" =~ ^EXIT:([0-9]+)$ ]]; then
        status="${BASH_REMATCH[1]}"
        output=$(echo "$output" | head -n -1)
    fi
    # Split into lines array
    IFS=$'\n' read -ra lines <<< "$output" 2>/dev/null || lines=()
}

##############################################################################
# Assertion helpers
##############################################################################
assert_success() {
    if [[ $status -ne 0 ]]; then
        echo "Expected success but got exit status $status"
        echo "Output: $output"
        return 1
    fi
}

assert_failure() {
    if [[ $status -eq 0 ]]; then
        echo "Expected failure but command succeeded"
        echo "Output: $output"
        return 1
    fi
}

assert_output() {
    local expected="$1"
    if [[ "$output" != *"$expected"* ]]; then
        echo "Expected output to contain: $expected"
        echo "Actual output: $output"
        return 1
    fi
}

assert_output_not() {
    local unexpected="$1"
    if [[ "$output" == *"$unexpected"* ]]; then
        echo "Expected output NOT to contain: $unexpected"
        echo "Actual output: $output"
        return 1
    fi
}

assert_equal() {
    if [[ "$1" != "$2" ]]; then
        echo "Expected '$1' to equal '$2'"
        return 1
    fi
}

assert_file_exists() {
    if [[ ! -f "$1" ]]; then
        echo "Expected file to exist: $1"
        return 1
    fi
}

assert_dir_exists() {
    if [[ ! -d "$1" ]]; then
        echo "Expected directory to exist: $1"
        return 1
    fi
}

skip() {
    local reason="${1:-no reason given}"
    echo "SKIP: $reason"
    return 0
}

##############################################################################
# Test file execution engine
##############################################################################
_run_test_file() {
    local test_file="$1"
    local file_passed=0
    local file_failed=0

    echo ""
    echo "$(tput bold 2>/dev/null || true)▶  $(basename "$test_file")$(tput sgr0 2>/dev/null || true)"
    echo "$(printf '─%.0s' {1..60})"

    # Source the test file to discover @test blocks
    # We parse it ourselves to collect test names then re-source per test
    local test_names=()
    while IFS= read -r line; do
        if [[ "$line" =~ ^@test[[:space:]]+\"(.+)\"[[:space:]]*\{ ]]; then
            test_names+=("${BASH_REMATCH[1]}")
        elif [[ "$line" =~ ^@test[[:space:]]+'(.+)'[[:space:]]*\{ ]]; then
            test_names+=("${BASH_REMATCH[1]}")
        fi
    done < "$test_file"

    for test_name in "${test_names[@]}"; do
        (( TESTS_RUN++ )) || true

        # Run each test in a subshell for isolation
        local test_result
        local test_output
        test_output=$(
            set +e
            # Propagate the test file path so setup() can compute PROJECT_ROOT correctly
            export BATS_TEST_FILENAME="$test_file"
            # Declare bats helpers in subshell
            # shellcheck disable=SC1090
            source "$BATS_LIB/helpers.bash"

            # Source test file
            # Define @test as a function runner
            _BATS_CURRENT_TEST=""
            _BATS_TEST_BODY=""
            _BATS_COLLECTING=false

            # Re-implement @test collection in subshell
            eval "$(
              python3 - "$test_file" "$test_name" << 'PYEOF'
import sys, re

test_file = sys.argv[1]
target_test = sys.argv[2]

with open(test_file) as f:
    content = f.read()

# Extract setup/teardown
def extract_func(name, text):
    m = re.search(rf'^{name}\s*\(\)\s*\{{(.*?)^}}', text, re.MULTILINE | re.DOTALL)
    return m.group(1).strip() if m else ''

setup_body = extract_func('setup', content)
teardown_body = extract_func('teardown', content)

# Find the specific @test
# Match: @test "name" { ... }  (brace-balanced)
in_test = False
depth = 0
body_lines = []
found = False

lines = content.split('\n')
for line in lines:
    if not in_test:
        m = re.match(r'''@test\s+["'](.+?)["']\s*\{''', line)
        if m and m.group(1) == target_test:
            in_test = True
            depth = line.count('{') - line.count('}')
            continue
    else:
        depth += line.count('{') - line.count('}')
        if depth <= 0:
            in_test = False
            found = True
            break
        body_lines.append(line)

if not found:
    print(f'echo "ERROR: test not found: {target_test}"; exit 1')
else:
    body = '\n'.join(body_lines)
    out = ''
    if setup_body:
        out += f'setup() {{\n{setup_body}\n}}\nsetup || true\n'
    else:
        out += 'setup() { :; }\n'
    if teardown_body:
        out += f'teardown() {{\n{teardown_body}\n}}\n'
    else:
        out += 'teardown() { :; }\n'
    out += f'(\n{body}\n); _TEST_STATUS=$?; teardown || true; exit $_TEST_STATUS'
    print(out)
PYEOF
            )"
            exit $?
        )
        test_result=$?

        if [[ $test_result -eq 0 ]]; then
            (( TESTS_PASSED++ )) || true
            (( file_passed++ )) || true
            printf " $(tput setaf 2 2>/dev/null || true)✓$(tput sgr0 2>/dev/null || true) %s\n" "$test_name"
        else
            (( TESTS_FAILED++ )) || true
            (( file_failed++ )) || true
            FAILED_TESTS+=("$test_name")
            printf " $(tput setaf 1 2>/dev/null || true)✗$(tput sgr0 2>/dev/null || true) %s\n" "$test_name"
            if [[ -n "$test_output" ]]; then
                echo "$test_output" | sed 's/^/   │ /'
            fi
        fi
    done

    echo ""
    echo "  $file_passed passed, $file_failed failed"
}

##############################################################################
# Main
##############################################################################
main() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: bats <test-file.bats> [test-file2.bats ...]"
        echo "       bats tests/            (run all *.bats in directory)"
        exit 1
    fi

    if [[ "$1" == "--version" ]]; then
        echo "Bats $VERSION"
        exit 0
    fi

    local files=()
    for arg in "$@"; do
        if [[ -d "$arg" ]]; then
            while IFS= read -r f; do files+=("$f"); done \
                < <(find "$arg" -name "*.bats" | sort)
        elif [[ -f "$arg" ]]; then
            files+=("$arg")
        fi
    done

    local start_time
    start_time=$(date +%s)

    echo ""
    echo "$(tput bold 2>/dev/null || true)╔══════════════════════════════════════════════════════════════╗"
    echo "║            BATS — Bash Automated Testing System             ║"
    echo "╚══════════════════════════════════════════════════════════════╝$(tput sgr0 2>/dev/null || true)"

    for f in "${files[@]}"; do
        _run_test_file "$f"
    done

    local end_time elapsed
    end_time=$(date +%s)
    elapsed=$(( end_time - start_time ))

    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    local rate=0
    [[ $TESTS_RUN -gt 0 ]] && rate=$(( TESTS_PASSED * 100 / TESTS_RUN ))
    printf "  Tests run:    %d\n" "$TESTS_RUN"
    printf "  Passed:       $(tput setaf 2 2>/dev/null || true)%d$(tput sgr0 2>/dev/null || true)\n" "$TESTS_PASSED"
    printf "  Failed:       $(tput setaf 1 2>/dev/null || true)%d$(tput sgr0 2>/dev/null || true)\n" "$TESTS_FAILED"
    printf "  Pass rate:    %d%%\n" "$rate"
    printf "  Time:         %ds\n" "$elapsed"
    echo ""

    if [[ ${#FAILED_TESTS[@]} -gt 0 ]]; then
        echo "  Failed tests:"
        for t in "${FAILED_TESTS[@]}"; do
            echo "    $(tput setaf 1 2>/dev/null || true)✗$(tput sgr0 2>/dev/null || true) $t"
        done
        echo ""
    fi

    if [[ $TESTS_FAILED -eq 0 ]]; then
        echo "  $(tput setaf 2 2>/dev/null || true)$(tput bold 2>/dev/null || true)✓ ALL TESTS PASSED$(tput sgr0 2>/dev/null || true)"
    else
        echo "  $(tput setaf 1 2>/dev/null || true)$(tput bold 2>/dev/null || true)✗ SOME TESTS FAILED$(tput sgr0 2>/dev/null || true)"
    fi
    echo ""

    [[ $TESTS_FAILED -eq 0 ]]
}

main "$@"
