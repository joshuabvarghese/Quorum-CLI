{
  "uid": "quorum-cluster-overview",
  "title": "Quorum-CLI — Cluster Overview",
  "tags": ["quorum", "distributed-systems"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Cluster Health",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "quorum-prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0":   { "text": "UNHEALTHY", "color": "red" } } },
            { "type": "value", "options": { "0.5": { "text": "DEGRADED",  "color": "yellow" } } },
            { "type": "value", "options": { "1":   { "text": "HEALTHY",   "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green",  "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "quorum_cluster_health",
          "legendFormat": "{{cluster}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Nodes Total vs Healthy",
      "type": "bargauge",
      "gridPos": { "x": 4, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "quorum-prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "quorum_nodes_total",   "legendFormat": "Total — {{cluster}}" },
        { "expr": "quorum_nodes_healthy", "legendFormat": "Healthy — {{cluster}}" }
      ]
    },
    {
      "id": 3,
      "title": "Quorum Status",
      "type": "stat",
      "gridPos": { "x": 10, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "quorum-prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "LOST",  "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "HELD",  "color": "green" } } }
          ]
        }
      },
      "targets": [
        { "expr": "quorum_has_quorum", "legendFormat": "{{cluster}}" }
      ]
    },
    {
      "id": 4,
      "title": "Leader Elections (rate/min)",
      "type": "timeseries",
      "gridPos": { "x": 14, "y": 0, "w": 10, "h": 4 },
      "datasource": { "uid": "quorum-prometheus" },
      "targets": [
        {
          "expr": "rate(quorum_leader_elections_total[1m]) * 60",
          "legendFormat": "Elections/min — {{cluster}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Nodes Down",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "datasource": { "uid": "quorum-prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red",   "value": 2 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "quorum_nodes_down", "legendFormat": "Down — {{cluster}}" }
      ]
    },
    {
      "id": 6,
      "title": "Cluster Logs (live tail)",
      "type": "logs",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 6 },
      "datasource": { "uid": "quorum-loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{job=\"quorum-cluster-manager\"}",
          "legendFormat": ""
        }
      ]
    }
  ]
}
